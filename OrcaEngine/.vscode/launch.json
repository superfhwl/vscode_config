        {
            "name": "Launch OrcaEditor (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/../OrcaStudio/build/bin/profile/OrcaEditor",
            "args": ["--lockFps60"],
            "cwd": "${workspaceFolder}/../OrcaStudio/build/bin/profile",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${workspaceFolder}/../OrcaStudio/build/bin/profile:${env:LD_LIBRARY_PATH}"
                }
            ],
            "initCommands": [
                "settings set symbols.load-on-demand true",
                "settings set target.process.stop-on-sharedlibrary-events false"
            ],
            "stopOnEntry": false,
            "sourceMap": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        },
        {
            "name": "Launch GameLauncher (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/../OrcaStudio/build/bin/profile/OrcaStudio.GameLauncher",
            "args": ["--lockFps60",
                     "--r_width", "960", "--r_height", "540",
                     "--LoadLevel", "water_test_3"],
            "cwd": "${workspaceFolder}/../OrcaStudio/build/bin/profile",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${workspaceFolder}/../OrcaStudio/build/bin/profile:${env:LD_LIBRARY_PATH}"
                }
            ],
            "initCommands": [
                "settings set symbols.load-on-demand true",
                "settings set target.process.stop-on-sharedlibrary-events false"
            ],
            "stopOnEntry": false,
            "sourceMap": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        },
        {
            "name": "Attach to Program (LLDB)",
            "type": "lldb",
            "request": "attach",
            "pid": "${command:pickProcess}",
            "initCommands": [
                "settings set symbols.load-on-demand true",
                "settings set target.process.stop-on-sharedlibrary-events false"
            ],
            "stopOnEntry": false,
            "sourceMap": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        }
    ]
}
