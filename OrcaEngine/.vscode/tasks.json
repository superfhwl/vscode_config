        // Linux Tasks
        
        {
            "label": "Build OrcaStudio Profile Linux",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "OrcaEditor",
                "OrcaStudio.GameLauncher",
                "AssetBundler",
                "AssetBundlerBatch",
                "MujocoImporterBatch",
                "OrcaBuilderHubCli",
                "copy_usd",
                "--config",
                "profile"
            ],
            "options": {
                "cwd": "${workspaceFolder}/../OrcaStudio",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build OrcaStudio Profile Linux (with PySide & Monolithic)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "OrcaPySide",
                "--config",
                "profile"
            ],
            "options": {
                "cwd": "${workspaceFolder}/../OrcaStudio_Monolithic",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate Mujoco Protobuf Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos",
                "--cpp_out=${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos",
                "${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos/mjc_message.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Generate Mujoco gRPC Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos",
                "--grpc_out=${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos",
                "--plugin=protoc-gen-grpc=${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/grpc_cpp_plugin",
                "${workspaceFolder}/Gems/Mujoco/Code/Source/GrpcService/protos/mjc_message.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Generate ParticleRender Protobuf Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos",
                "--cpp_out=${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos",
                "${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos/particle_data.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Generate EditService Protobuf Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem",
                "--cpp_out=${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem",
                "${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem/edit_service.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Generate EditService gRPC Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem",
                "--grpc_out=${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem",
                "--plugin=protoc-gen-grpc=${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/grpc_cpp_plugin",
                "${workspaceFolder}/Gems/Mujoco/Code/Source/ActorSystem/edit_service.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Generate ParticleRender gRPC Linux",
            "type": "shell",
            "command": "${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/protoc",
            "args": [
                "--proto_path=${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos",
                "--grpc_out=${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos",
                "--plugin=protoc-gen-grpc=${workspaceFolder}/../../.orca/3rdParty/packages/grpc-1.51.1-rev2-linux/grpc/bin/grpc_cpp_plugin",
                "${workspaceFolder}/Gems/ParticleRender/Code/Source/Grpc/protos/particle_data.proto"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build ParticleRender TestClient Linux",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cd ${workspaceFolder}/Gems/ParticleRender/Code/TestClient && mkdir -p build && cd build && cmake .. && make -j8"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "options": {
                "cwd": "${workspaceFolder}/Gems/ParticleRender/Code/TestClient"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate GDB Index Linux",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "for file in ${workspaceFolder}/../OrcaStudio/build/bin/profile/*; do if [[ -x \"$file\" || \"$file\" == *.so ]]; then echo \"Generating GDB index for $file\"; gdb-add-index \"$file\"; fi; done"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "List Processes for LLDB Attach Linux",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "echo '=== OrcaEditor Processes ===' && ps aux | grep -E 'OrcaEditor|GameLauncher' | grep -v grep || echo 'No OrcaEditor/GameLauncher processes found'; echo ''; echo '=== All Processes (filter by name) ===' && ps aux | head -1 && echo 'Use: ps aux | grep <process_name>'"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": false
            },
            "problemMatcher": []
        }
    ]
}
